# Footverse — variáveis de ambiente
# Copie para .env e ajuste os valores antes de rodar.

# ── Banco de dados ────────────────────────────────────────────────────────────
# SQLite (padrão, zero-config):
DATABASE_URL=sqlite:////data/footverse.db

# PostgreSQL (produção):
# DATABASE_URL=postgresql+psycopg://fv:senha@db:5432/footverse

# ── Motor do jogo ─────────────────────────────────────────────────────────────
# Seed do mundo — mude para reiniciar o mercado e os NPCs numa nova instância.
FOOTVERSE_SEASON_SECRET=FOOTVERSE_S1

# ── API ───────────────────────────────────────────────────────────────────────
# Origins permitidos pelo CORS (separados por vírgula).
# Use * apenas em desenvolvimento.
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# ── Relógio de mundo (Fase 3) ──────────────────────────────────────────────────
# Duração de uma rodada em segundos reais. Padrão: 1 dia (86400).
# Reduza para acelerar em dev/demo (ex: 60 = 1 rodada/minuto).
ROUND_DURATION_SECONDS=86400

# Intervalo entre checagens do relógio em segundos (não precisa ser igual
# a ROUND_DURATION_SECONDS — só precisa ser menor para não perder o tick).
CLOCK_CHECK_INTERVAL_SECONDS=60

# ── Agentes de IA (opcional — instale [agents] para ativar) ──────────────────
# Necessário apenas se quiser usar Scout/Coach/Finance/ClubManager.
OPENAI_API_KEY=sk-proj-...
FOOTVERSE_AGENT_MODEL=gpt-4o-mini
